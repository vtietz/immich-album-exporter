## Container runtime settings
PUID=1000
PGID=1000
TZ=UTC
IMMICH_ALBUM_EXPORTER_IMAGE=ghcr.io/vtietz/immich-album-exporter:latest
IMMICH_EXPORTER_CONFIG_DIR=./config
IMMICH_EXPORTER_DATA_DIR=./data
IMMICH_EXPORTER_TARGET_DIR=./target

## Exporter configuration values referenced by config/config.example.yml
IMMICH_BASE_URL=http://immich-server:2283/api
# Use either IMMICH_API_KEY or IMMICH_ACCESS_TOKEN. Most setups should use an API key.
IMMICH_API_KEY=
IMMICH_ACCESS_TOKEN=
# Optional: single Immich user ID, not an array. Leave empty to use the API key user's own visibility.
IMMICH_SELECTION_USER_ID=
# Optional: use YYYY-MM-DD or a full ISO timestamp like 2026-01-01T00:00:00Z
IMMICH_SELECTION_START_DATE=

## Internal e2e/test setting used by ./run.sh test
IMMICH_VERSION=v2

## Internal helper set by ./run.sh for the e2e compose overlay
# PROJECT_ROOT=/absolute/path/to/repo
